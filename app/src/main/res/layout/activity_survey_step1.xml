<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="24dp">

    <!-- Header Section -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        app:tint="@color/color_gray_200"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1 / 5"
        android:textColor="@color/color_slategray"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Titles -->
    <TextView
        android:id="@+id/tv_step_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Căn phòng mong muốn của bạn"
        android:textColor="@color/color_slategray"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_question"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bạn muốn ở đâu?"
        android:textColor="@color/color_gray_200"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_step_title"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Survey Options -->
    <LinearLayout
        android:id="@+id/layout_options"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tv_question"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/opt_phong_tro"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Phòng trọ"
            android:textAlignment="viewStart"
            android:textAllCaps="false"
            android:textColor="@color/color_darkslategray"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:strokeColor="@color/color_border_light"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/opt_nha_nguyen_can"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Nhà nguyên căn"
            android:textAlignment="viewStart"
            android:textAllCaps="false"
            android:textColor="@color/color_darkslategray"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:strokeColor="@color/color_border_light"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/opt_chung_cu"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Chung cư"
            android:textAlignment="viewStart"
            android:textAllCaps="false"
            android:textColor="@color/color_darkslategray"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:strokeColor="@color/color_border_light"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/opt_chung_cu_mini"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Chung cư mini"
            android:textAlignment="viewStart"
            android:textAllCaps="false"
            android:textColor="@color/color_darkslategray"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:strokeColor="@color/color_border_light"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/opt_khac"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Khác"
            android:textAlignment="viewStart"
            android:textAllCaps="false"
            android:textColor="@color/color_darkslategray"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:strokeColor="@color/color_border_light" />

    </LinearLayout>

    <!-- Bottom Navigation -->
    <Button
        android:id="@+id/btn_next"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Tiếp theo"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"
        android:background="@drawable/btn_rounded"
        app:backgroundTint="@color/color_steelblue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
