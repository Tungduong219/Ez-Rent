<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="24dp">

    <!-- Header Section -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2 / 5"
        android:textColor="@color/color_slategray"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Titles -->
    <TextView
        android:id="@+id/tv_step_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Căn phòng mong muốn của bạn"
        android:textColor="@color/color_slategray"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.03"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_question"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Căn phòng của bạn ở đâu?"
        android:textColor="@color/color_gray_200"
        android:textSize="26sp"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold"
        android:letterSpacing="-0.01"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_step_title"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Illustration Image (Thay cho bản đồ) -->
    <ImageView
        android:id="@+id/iv_location_illustration"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginTop="24dp"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_menu_mapmode"
        app:layout_constraintTop_toBottomOf="@id/tv_question"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Select City -->
    <TextView
        android:id="@+id/lbl_city"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tỉnh / Thành phố"
        android:textStyle="bold"
        android:textColor="@color/color_darkslategray"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/iv_location_illustration"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spinner_city"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/btn_outlined"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/lbl_city"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Select District -->
    <TextView
        android:id="@+id/lbl_district"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quận / Huyện"
        android:textStyle="bold"
        android:textColor="@color/color_darkslategray"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/spinner_city"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spinner_district"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/btn_outlined"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/lbl_district"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Next Button -->
    <Button
        android:id="@+id/btn_next"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Tiếp theo"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"
        android:background="@drawable/btn_rounded"
        app:backgroundTint="@color/color_steelblue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
