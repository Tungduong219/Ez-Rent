<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="24dp">

    <!-- Header Section -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3 / 5"
        android:textColor="@color/color_slategray"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Titles -->
    <TextView
        android:id="@+id/tv_step_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Căn phòng mong muốn của bạn"
        android:textColor="@color/color_slategray"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_question"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn khoảng giá\nhợp túi tiền nha"
        android:textColor="@color/color_gray_200"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_step_title"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Price Options Container -->
    <LinearLayout
        android:id="@+id/layout_grid_replacement"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_question"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/opt_1_2"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="1 - 2 triệu"
                android:textAllCaps="false"
                android:textColor="@color/color_darkslategray"
                app:cornerRadius="16dp"
                app:strokeColor="@color/color_border_light"
                android:layout_margin="4dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/opt_2_3"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="2 - 3 triệu"
                android:textAllCaps="false"
                android:textColor="@color/color_darkslategray"
                app:cornerRadius="16dp"
                app:strokeColor="@color/color_border_light"
                android:layout_margin="4dp"/>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/opt_3_45"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="3 - 4.5 triệu"
                android:textAllCaps="false"
                android:textColor="@color/color_darkslategray"
                app:cornerRadius="16dp"
                app:strokeColor="@color/color_border_light"
                android:layout_margin="4dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/opt_45_6"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="4.5 - 6 triệu"
                android:textAllCaps="false"
                android:textColor="@color/color_darkslategray"
                app:cornerRadius="16dp"
                app:strokeColor="@color/color_border_light"
                android:layout_margin="4dp"/>
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/opt_6_8"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="6 - 8 triệu"
                android:textAllCaps="false"
                android:textColor="@color/color_darkslategray"
                app:cornerRadius="16dp"
                app:strokeColor="@color/color_border_light"
                android:layout_margin="4dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/opt_8_10"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="8 - 10 triệu"
                android:textAllCaps="false"
                android:textColor="@color/color_darkslategray"
                app:cornerRadius="16dp"
                app:strokeColor="@color/color_border_light"
                android:layout_margin="4dp"/>
        </LinearLayout>

        <!-- Row 4 (Single centered item) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <!-- Empty space to align the 10+ button to the left -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/opt_10plus"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="Hơn 10 triệu"
                android:textAllCaps="false"
                android:textColor="@color/color_darkslategray"
                app:cornerRadius="16dp"
                app:strokeColor="@color/color_border_light" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_margin="4dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Next Button -->
    <Button
        android:id="@+id/btn_next"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Tiếp theo"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"
        android:background="@drawable/btn_rounded"
        app:backgroundTint="@color/color_steelblue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
